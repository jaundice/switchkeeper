{
  "name": "@switchkeeper/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Switchkeeper Electron desktop app (self-contained; engine bundled in-process)",
  "homepage": "https://github.com/jaundice/switchkeeper#readme",
  "bugs": "https://github.com/jaundice/switchkeeper/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaundice/switchkeeper.git",
    "directory": "packages/desktop"
  },
  "author": "jaundice",
  "license": "MIT",
  "main": "main.cjs",
  "scripts": {
    "build:engine": "esbuild ../engine/src/index.ts --bundle --platform=node --format=cjs --outfile=build/engine.cjs",
    "start": "npm run build:engine && electron .",
    "dist": "npm run build:engine && electron-builder --publish never"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0"
  },
  "build": {
    "appId": "io.github.jaundice.switchkeeper",
    "productName": "Switchkeeper",
    "files": ["main.cjs", "preload.cjs", "renderer/**/*", "build/**/*"],
    "directories": { "output": "release" },
    "win": { "target": "nsis" },
    "mac": { "target": "dmg", "category": "public.app-category.utilities" },
    "linux": { "target": ["AppImage", "deb"], "category": "Network" }
  }
}
